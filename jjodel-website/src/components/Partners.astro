---
const partners = [
  { abbr: 'UDA', name: "Univ. dell'Aquila" },
  { abbr: 'MDU', name: 'Mälardalen University' },
  { abbr: 'FBK', name: 'Fondazione Bruno Kessler' },
  { abbr: 'EU', name: 'AIM-PRO Project', highlight: true },
];
---

<section class="partners section">
  <p class="section-label">Research partners</p>
  <div class="partners__list">
    {partners.map(p => (
      <div class="partners__item">
        <div class:list={['partners__badge', { 'partners__badge--eu': p.highlight }]}>
          {p.abbr}
        </div>
        <span class="partners__name">{p.name}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .partners__list {
    display: flex;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .partners__item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .partners__badge {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: var(--color-bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.647rem;
    color: var(--color-text-secondary);
    font-weight: 600;
    flex-shrink: 0;
  }

  .partners__badge--eu {
    background: var(--jj-blue-50);
    color: var(--jj-blue-600);
  }

  .partners__name {
    font-size: 0.882rem;
    color: var(--color-text-secondary);
  }
</style>
