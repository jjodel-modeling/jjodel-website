---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__brand">
      <a href="/">
        <img src="/jjodel-logo-light.png" alt="Jjodel" height="24" />
      </a>
      <p>Made by the SWEN group</p>
      <p>Universit&agrave; degli Studi dell'Aquila</p>
    </div>

    <div class="footer__columns">
      <div class="footer__col">
        <p class="footer__heading">Project</p>
        <a href="/research/">Research</a>
        <a href="/team/">Team</a>
        <a href="/sponsor/">Sponsor</a>
      </div>
      <div class="footer__col">
        <p class="footer__heading">Resources</p>
        <a href="https://docs.jjodel.io" target="_blank" rel="noopener noreferrer">Documentation ↗</a>
        <a href="https://github.com/jjodel-modeling" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
        <a href="https://opencollective.com/jjodel" target="_blank" rel="noopener noreferrer">OpenCollective ↗</a>
      </div>
      <div class="footer__col">
        <p class="footer__heading">Legal</p>
        <a href="https://github.com/jjodel-modeling/jjodel-frontend/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">MIT License</a>
        <a href="#">Privacy</a>
      </div>
    </div>
  </div>

  <div class="footer__bottom container">
    <p>Made with ❤️ in L'Aquila, Italy</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-top: 2.5rem;
    margin-top: 2rem;
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 3rem;
  }

  .footer__brand {
    flex-shrink: 0;
  }

  .footer__brand img {
    height: 24px;
    width: auto;
    margin-bottom: 10px;
  }

  .footer__brand p {
    font-size: 0.824rem;
    color: var(--color-text-tertiary);
    margin-bottom: 2px;
  }

  .footer__columns {
    display: flex;
    gap: 3rem;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer__heading {
    font-size: 0.824rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: 6px;
  }

  .footer__col a {
    font-size: 0.824rem;
    color: var(--color-text-tertiary);
    text-decoration: none;
  }

  .footer__col a:hover {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .footer__bottom {
    margin-top: 2.5rem;
    padding-bottom: 2rem;
    text-align: center;
  }

  .footer__bottom p {
    font-size: 0.765rem;
    color: var(--color-text-tertiary);
  }

  @media (max-width: 768px) {
    .footer__inner {
      flex-direction: column;
      gap: 2rem;
    }

    .footer__columns {
      flex-wrap: wrap;
      gap: 2rem;
    }
  }
</style>
