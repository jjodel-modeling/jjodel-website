<section class="hero">
  <p class="hero__label">Open-source metamodeling platform</p>
  <h1 class="hero__title">Define languages.<br>Create models.<br>See results instantly.</h1>
  <p class="hero__subtitle">
    Jjodel is a cloud-based metamodeling workbench for research and education.
    Define your DSL, create models, apply transformations, and collaborate in real time.
    No installation. No code generation. Everything runs in the browser.
  </p>
  <div class="hero__actions">
    <a href="https://app.jjodel.io" class="btn btn--primary">Try Jjodel →</a>
    <a href="https://docs.jjodel.io" class="btn btn--secondary">Read the docs</a>
  </div>
</section>

<style>
  .hero {
    padding: 3rem 0 3.5rem;
  }

  .hero__label {
    font-size: 0.706rem;
    font-weight: 600;
    color: var(--jj-amber-600);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 1rem;
  }

  .hero__title {
    font-size: 3.06rem;
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .hero__subtitle {
    font-size: 1.06rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 640px;
    margin-bottom: 1.75rem;
  }

  .hero__actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  @media (max-width: 768px) {
    .hero__title {
      font-size: 2rem;
    }

    .hero__subtitle {
      font-size: 1rem;
    }

    .hero__actions {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
