---
import BaseLayout from '../layouts/BaseLayout.astro';

const publications = [
  {
    authors: 'Bucchiarone, A., Di Rocco, J., Di Vincenzo, D., Pierantonio, A.',
    title: 'Modeling in Jjodel: towards bridging complexity and usability in model-driven engineering',
    venue: 'Software and Systems Modeling (SoSyM)',
    year: 2025,
    doi: '10.1007/s10270-025-01324-y',
    fulltext: 'https://rdcu.be/eMBFz',
  },
  {
    authors: 'Bucchiarone, A., Di Rocco, J., Di Vincenzo, D., Pierantonio, A.',
    title: 'From OCL to JSX: declarative constraint modeling in modern SaaS tools',
    venue: 'Intl Workshop on OCL (accepted)',
    year: 2025,
    fulltext: 'https://arxiv.org/abs/2509.17629',
  },
  {
    authors: 'Tolvanen, J. P., Kelly, S., Di Rocco, J., Pierantonio, A., Tinella, G.',
    title: 'A framework for evaluating tool support for co-evolution of modeling languages, tools and models',
    venue: 'Software and Systems Modeling',
    year: 2025,
    doi: '10.1007/s10270-024-01218-5',
  },
];

const talks = [
  { title: 'Jjodel and Layout-Sensitive Notation', speaker: 'Alfonso Pierantonio', venue: 'LangDev 2025, Amsterdam', url: 'https://langdevcon.org/2025/abstracts#29' },
  { title: 'Real-Time Rooms for Collaborative Modeling', speaker: 'Juri Di Rocco', venue: 'LangDev 2025, Amsterdam', url: 'https://langdevcon.org/2025/abstracts#40' },
  { title: 'The Evolutionary Life of Metamodels', speaker: 'Alfonso Pierantonio', venue: 'Keynote, MODELS 2025, Grand Rapids', url: 'https://models-and-evolution.github.io/' },
  { title: 'The Cognitive Science of Modeling Tools', speaker: 'Alfonso Pierantonio', venue: 'Guest Lecture, TU Wien, Jun 2025', url: 'https://informatics.tuwien.ac.at/news/2876' },
  { title: 'Transparency of Tools: Beyond Usability in Modeling Tools', speaker: 'Alfonso Pierantonio', venue: 'Keynote, MODELSWARD 2025, Porto', url: 'https://modelsward.scitevents.org/KeynoteSpeakers.aspx?y=2025#3' },
  { title: 'Achieving Better Workbenches in MDE', speaker: 'Alfonso Pierantonio', venue: 'Keynote, MLE 2024', url: 'https://mleworkshop.github.io/editions/mle2024/' },
];

const comparisons = [
  { title: 'LSP/GLSP vs Jjodel', desc: 'Architecture and interaction model differences' },
  { title: 'EMF vs Jjodel', desc: 'Generative vs reflective metamodeling' },
  { title: 'Co-evolution', desc: 'Live evolution across Jjodel, EMF/Sirius, MetaEdit+' },
];
---

<BaseLayout title="Research — Jjodel" description="Scientific foundations behind Jjodel: publications, talks, and technical comparisons.">
  <section class="page-header">
    <h1>Research</h1>
    <p class="page-header__subtitle">Jjodel is a research project. These are the scientific foundations behind it.</p>
  </section>

  <section class="section">
    <h2>Publications</h2>
    <div class="pub-list">
      {publications.map(pub => (
        <div class="pub">
          <p class="pub__authors">{pub.authors}</p>
          <p class="pub__title">{pub.title}</p>
          <p class="pub__venue">{pub.venue}, {pub.year}{pub.doi ? `. DOI: ${pub.doi}` : ''}</p>
          {pub.fulltext && <a href={pub.fulltext} class="pub__link" target="_blank" rel="noopener noreferrer">Full text ↗</a>}
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Talks and keynotes</h2>
    <div class="talks-list">
      {talks.map(talk => (
        <div class="talk">
          {talk.url ? (
            <a href={talk.url} class="talk__title" target="_blank" rel="noopener noreferrer">{talk.title} ↗</a>
          ) : (
            <span class="talk__title">{talk.title}</span>
          )}
          <span class="talk__meta">{talk.speaker} — {talk.venue}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>How Jjodel compares</h2>
    <p class="comparisons__intro">These comparisons explain how Jjodel differs from existing metamodeling frameworks.</p>
    <div class="comparisons__grid">
      {comparisons.map(c => (
        <div class="card comparisons__card">
          <h3>{c.title}</h3>
          <p class="comparisons__desc">{c.desc}</p>
          <span class="comparisons__link">Read on docs.jjodel.io ↗</span>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 2.5rem 0 1rem;
  }

  .page-header__subtitle {
    font-size: 1.06rem;
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
  }

  .pub {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .pub:last-child {
    border-bottom: none;
  }

  .pub__authors {
    font-size: 0.824rem;
    color: var(--color-text-tertiary);
    margin-bottom: 4px;
  }

  .pub__title {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .pub__venue {
    font-size: 0.882rem;
    color: var(--color-text-secondary);
    margin-bottom: 6px;
  }

  .pub__link {
    font-size: 0.824rem;
    font-weight: 500;
  }

  .talk {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .talk:last-child {
    border-bottom: none;
  }

  .talk__title {
    font-size: 0.941rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
  }

  a.talk__title:hover {
    text-decoration: underline;
  }

  .talk__meta {
    font-size: 0.824rem;
    color: var(--color-text-tertiary);
  }

  .comparisons__intro {
    font-size: 0.941rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .comparisons__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .comparisons__card h3 {
    margin-bottom: 6px;
  }

  .comparisons__desc {
    font-size: 0.882rem;
    color: var(--color-text-secondary);
    margin-bottom: 12px;
  }

  .comparisons__link {
    font-size: 0.824rem;
    color: var(--jj-blue-600);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .comparisons__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
