---
import BaseLayout from '../layouts/BaseLayout.astro';

const team = [
  { name: 'Alfonso Pierantonio', role: 'Professor', affiliation: "Università dell'Aquila", url: 'https://disim.univaq.it/AlfonsoPierantonio/', initials: 'AP' },
  { name: 'Juri Di Rocco', role: 'Assistant Professor', affiliation: "Università dell'Aquila", url: 'https://disim.univaq.it/JuriDiRocco', initials: 'JR' },
  { name: 'Antonio Bucchiarone', role: 'Associate Professor', affiliation: "Università dell'Aquila", url: 'https://disim.univaq.it/AntonioBucchiarone', initials: 'AB' },
  { name: 'Damiano Di Vincenzo', role: 'Chief Architect', affiliation: "Università dell'Aquila", initials: 'DV' },
  { name: 'Andrea Perelli', role: 'Software Engineer', affiliation: 'Private Consultant', initials: 'APe' },
  { name: 'Giordano Tinella', role: 'Former Member', affiliation: "Università dell'Aquila", initials: 'GT' },
];

const partners = [
  { name: 'Antonio Cicchetti', role: 'Professor', affiliation: 'Mälardalen University', initials: 'AC' },
  { name: 'Malvina Latifaj', role: 'Assistant Professor', affiliation: 'Mälardalen University', initials: 'ML' },
  { name: 'Robbert Jongeling', role: 'Senior Lecturer', affiliation: 'University of York', initials: 'RJ' },
];
---

<BaseLayout title="Team — Jjodel" description="The people behind Jjodel: the SWEN research group and international partners.">
  <section class="page-header">
    <h1>Team and partners</h1>
    <p class="page-header__subtitle">Jjodel is built by the SWEN research group at Università degli Studi dell'Aquila, Italy.</p>
  </section>

  <section class="section">
    <div class="people-grid">
      {team.map(person => (
        <div class="person-card">
          <div class="person-card__avatar">{person.initials}</div>
          <div>
            <p class="person-card__name">
              {person.url ? (
                <a href={person.url} target="_blank" rel="noopener noreferrer">{person.name}</a>
              ) : person.name}
            </p>
            <p class="person-card__role">{person.role}</p>
            <p class="person-card__aff">{person.affiliation}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Partners</h2>
    <div class="people-grid">
      {partners.map(person => (
        <div class="person-card">
          <div class="person-card__avatar">{person.initials}</div>
          <div>
            <p class="person-card__name">{person.name}</p>
            <p class="person-card__role">{person.role}</p>
            <p class="person-card__aff">{person.affiliation}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Contribute</h2>
    <p class="contrib__text">
      Jjodel is open-source and MIT-licensed. Contributions are welcome: bug reports, feature requests, documentation improvements, or code.
    </p>
    <div class="contrib__links">
      <a href="https://github.com/jjodel-modeling/jjodel-frontend/issues" target="_blank" rel="noopener noreferrer">View open issues on GitHub →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 2.5rem 0 1rem;
  }

  .page-header__subtitle {
    font-size: 1.06rem;
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
  }

  .people-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .person-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .person-card__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.824rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }

  .person-card__name {
    font-size: 0.941rem;
    font-weight: 500;
    margin-bottom: 2px;
  }

  .person-card__name a {
    text-decoration: none;
    color: var(--color-text);
  }

  .person-card__name a:hover {
    text-decoration: underline;
  }

  .person-card__role {
    font-size: 0.824rem;
    color: var(--color-text-secondary);
    margin-bottom: 1px;
  }

  .person-card__aff {
    font-size: 0.765rem;
    color: var(--color-text-tertiary);
  }

  .contrib__text {
    font-size: 0.941rem;
    color: var(--color-text-secondary);
    max-width: 560px;
    margin-bottom: 1rem;
  }

  .contrib__links a {
    font-size: 0.882rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .people-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
