---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const activities = await getCollection('activity', ({ data }) => !data.draft);
const publications = await getCollection('publications');

type FeedItem = {
  type: 'talk' | 'keynote' | 'paper' | 'release' | 'project';
  title: string;
  venue: string;
  date: Date;
  url?: string;
};

const feed: FeedItem[] = [
  ...activities.map((a): FeedItem => ({
    type: a.data.type,
    title: a.data.title,
    venue: a.data.venue,
    date: a.data.date,
    url: a.data.url,
  })),
  ...publications.map((p): FeedItem => ({
    type: 'paper',
    title: p.data.title,
    venue: `${p.data.venue}, ${p.data.year}`,
    date: p.data.date,
    url: p.data.doi ? `https://doi.org/${p.data.doi}` : p.data.fulltext,
  })),
].sort((a, b) => b.date.getTime() - a.date.getTime());

const typeLabel: Record<FeedItem['type'], string> = {
  paper: 'Paper',
  talk: 'Talk',
  keynote: 'Keynote',
  release: 'Release',
  project: 'Project',
};
---

<BaseLayout
  title="Activity | Jjodel"
  description="Full archive of talks, publications, and project updates from the Jjodel team."
>
  <section class="section">
    <div class="container">
      <h1>Activity</h1>
      <p class="muted intro">
        Talks, publications, and project updates from the Jjodel team.
      </p>

      <ul class="feed">
        {
          feed.map((item) => (
            <li class="feed-row">
              <span class="feed-type tertiary">{typeLabel[item.type]}</span>
              <span class="feed-title">
                {item.url ? (
                  <a href={item.url} rel="noopener">
                    {item.title} ↗
                  </a>
                ) : (
                  item.title
                )}
              </span>
              {item.venue && (
                <span class="feed-venue tertiary">{item.venue}</span>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    max-width: 720px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .feed {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .feed-row {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: 1.25rem;
    align-items: baseline;
    padding: 14px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .feed-row:last-child {
    border-bottom: none;
  }

  .feed-type {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    font-weight: 500;
  }

  .feed-title {
    font-size: 16px;
    color: var(--color-text);
  }

  .feed-title a {
    color: var(--color-text);
  }

  .feed-title a:hover {
    color: var(--jj-blue-600);
  }

  .feed-venue {
    text-align: right;
    white-space: nowrap;
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .feed-row {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .feed-venue {
      text-align: left;
    }
  }
</style>
