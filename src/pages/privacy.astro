---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy | Jjodel"
  description="Jjodel website privacy information."
>
  <section class="section">
    <div class="container">
      <h1>Privacy</h1>

      <h2 class="mt-xl">Cookies</h2>
      <p class="muted">
        This site does not use cookies. No analytics, tracking, or profiling
        cookies are set.
      </p>

      <h2 class="mt-xl">Third-party resources</h2>
      <p class="muted">
        This site loads fonts from Google Fonts (fonts.googleapis.com) and
        icons from jsDelivr CDN (cdn.jsdelivr.net). These services may log
        standard HTTP request data (IP address, browser type) according to
        their own privacy policies. No data is shared with these services by
        Jjodel.
      </p>

      <h2 class="mt-xl">Hosting</h2>
      <p class="muted">
        This site is hosted on GitHub Pages. GitHub may collect technical
        information as described in the{' '}
        <a
          href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement"
          rel="noopener noreferrer"
          target="_blank"
        >
          GitHub Privacy Statement ↗
        </a>.
      </p>

      <h2 class="mt-xl">The Jjodel application</h2>
      <p class="muted">
        The Jjodel application (app.jjodel.io) is a separate service with its
        own data handling. This privacy page covers only the jjodel.io
        website.
      </p>

      <h2 class="mt-xl">Contact</h2>
      <p class="muted">
        For questions about privacy, contact{' '}
        <a href="mailto:info@jjodel.io">info@jjodel.io</a>.
      </p>
    </div>
  </section>
</BaseLayout>
