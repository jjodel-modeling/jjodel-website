---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const pubs = (await getCollection('publications')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const talks = (await getCollection('activity'))
  .filter((a) => a.data.type === 'talk' || a.data.type === 'keynote')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const foundations = [
  {
    title: 'Tool Transparency',
    body: "Our recent work on the cognitive science of modeling tools investigates how tools mediate, extend, and sometimes constrain reasoning. Drawing on Heidegger's phenomenology and Piaget's theory of cognitive adaptation, we study when tools become transparent extensions of thought and when they obstruct it, aiming to design modeling environments that minimize cognitive friction.",
  },
  {
    title: 'Reactive Metamodeling',
    body: 'This builds on over a decade of research on co-evolution in model-driven engineering. We investigate how metamodel changes propagate to models, editors, and transformations, developing reactive strategies that eliminate the traditional compile-deploy cycle and enable immediate, live feedback during language evolution.',
  },
  {
    title: 'Cloud-Native Collaboration',
    body: 'Rooted in our experience with the EU LOWCOMOTE project on low-code development platforms, this line of research explores how cloud-native, browser-based architectures can democratize access to modeling tools. We study how shared, multi-view modeling environments support real-time collaboration at scale.',
  },
];

const talkTypeLabel: Record<string, string> = {
  talk: 'Talk',
  keynote: 'Keynote',
};
---

<BaseLayout
  title="Research | Jjodel"
  description="Foundations, comparisons, and peer-reviewed publications behind the Jjodel metamodeling workbench."
>
  <section class="section">
    <div class="container">
      <h1>Research</h1>
      <p class="muted intro">
        Jjodel is a research project developed at the SWEN group, Università
        degli Studi dell'Aquila. It investigates how to reduce accidental
        complexity in model-driven engineering tools through a reflective,
        cloud-native, and collaborative approach. Jjodel is part of EU-funded
        research and has been published in peer-reviewed venues including
        Software and Systems Modeling (SoSyM).
      </p>

      <h2 class="mt-xl">Foundations</h2>
      <div class="grid grid-3 mt-md">
        {
          foundations.map((f) => (
            <article class="card foundation-card">
              <h3 class="foundation-title">{f.title}</h3>
              <p class="foundation-body">{f.body}</p>
            </article>
          ))
        }
      </div>

      <h2 class="mt-xl">Publications</h2>
      <ul class="pub-list">
        {
          pubs.map((pub) => (
            <li class="pub-item">
              <p class="pub-citation">
                {pub.data.authors}. <strong>{pub.data.title}</strong>
                {pub.data.badge && (
                  <span class="pub-badge">{pub.data.badge}</span>
                )}
                . <em>{pub.data.venue}</em>, {pub.data.year}.
                {pub.data.doi && (
                  <>
                    {' '}
                    <a href={`https://doi.org/${pub.data.doi}`} rel="noopener">
                      doi:{pub.data.doi} ↗
                    </a>
                  </>
                )}
                {pub.data.fulltext && (
                  <>
                    {' · '}
                    <a href={pub.data.fulltext} rel="noopener">
                      Fulltext ↗
                    </a>
                  </>
                )}
              </p>
              <p class="pub-desc">{pub.data.abstract}</p>
            </li>
          ))
        }
      </ul>

      <h2 class="mt-xl">Talks and keynotes</h2>
      <ul class="talk-list">
        {
          talks.map((t) => (
            <li class="talk-item">
              <span class="talk-type tertiary">
                {talkTypeLabel[t.data.type]}
              </span>
              <span class="talk-title">
                {t.data.url ? (
                  <a href={t.data.url} rel="noopener">
                    {t.data.title} ↗
                  </a>
                ) : (
                  t.data.title
                )}
              </span>
              <span class="talk-meta tertiary">
                {t.data.speaker ? `${t.data.speaker} · ` : ''}
                {t.data.venue}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    max-width: 720px;
    line-height: 1.7;
  }

  .foundation-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .foundation-title {
    margin: 0;
    font-size: 16px;
    font-weight: 500;
  }

  .foundation-body {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .pub-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .pub-item {
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .pub-item:last-child {
    border-bottom: none;
  }

  .pub-citation {
    margin: 0 0 0.25rem;
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .pub-citation strong {
    color: var(--color-text);
    font-weight: 500;
  }

  .pub-badge {
    display: inline-block;
    background: #e0f2fe;
    color: #0284c7;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 2px 8px;
    border-radius: 4px;
    margin-left: 8px;
    vertical-align: middle;
  }

  .pub-desc {
    margin: 0;
    font-size: 13px;
    color: var(--color-text-tertiary);
    line-height: 1.6;
  }

  .talk-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .talk-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 1.25rem;
    align-items: baseline;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .talk-item:last-child {
    border-bottom: none;
  }

  .talk-type {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    font-weight: 500;
  }

  .talk-title {
    font-size: 15px;
    color: var(--color-text);
    font-weight: 500;
  }

  .talk-title a {
    color: var(--color-text);
  }

  .talk-title a:hover {
    color: var(--jj-blue-600);
  }

  .talk-meta {
    text-align: right;
    font-size: 13px;
  }

  @media (max-width: 768px) {
    .talk-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .talk-meta {
      text-align: left;
    }
  }
</style>
