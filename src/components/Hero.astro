---
---

<section class="hero">
  <div class="hero__text">
    <p class="hero__label">Open-source metamodeling platform</p>
    <h1 class="hero__title">
      Define languages.<br />
      Create models.<br />
      See results instantly.
    </h1>
    <p class="hero__subtitle">
      Cloud-based metamodeling workbench for research and education. Define
      your DSL, create models, apply transformations, and collaborate in real
      time. No installation. No code generation.
    </p>
    <div class="hero__actions">
      <a href="https://app.jjodel.io" class="btn btn-primary" rel="noopener">
        Try Jjodel →
      </a>
      <a href="https://docs.jjodel.io" class="btn btn-secondary" rel="noopener">
        Read the docs
      </a>
    </div>
  </div>

  <div class="hero__browser">
    <div class="hero__browser-bar">
      <div class="hero__browser-dots">
        <span class="hero__dot hero__dot--red"></span>
        <span class="hero__dot hero__dot--yellow"></span>
        <span class="hero__dot hero__dot--green"></span>
      </div>
      <span class="hero__browser-url">app.jjodel.io</span>
    </div>
    <div class="hero__browser-content">
      <img
        src="/jjodel-screenshot.png"
        alt="Jjodel Megamodel view showing metamodels, models, transformations, and their relationships"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 2rem 3.5rem;
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 2rem;
    align-items: center;
    min-height: 440px;
  }

  .hero__text {
    padding-right: 2rem;
  }

  .hero__label {
    font-size: 0.706rem;
    font-weight: 600;
    color: var(--jj-amber-600);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 0 1rem;
  }

  .hero__title {
    font-size: 2.75rem;
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
  }

  .hero__subtitle {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0 0 1.75rem;
  }

  .hero__actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero__browser {
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  .hero__browser-bar {
    background: var(--color-bg-secondary);
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .hero__browser-dots {
    display: flex;
    gap: 5px;
  }

  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .hero__dot--red {
    background: #f87171;
  }

  .hero__dot--yellow {
    background: #fbbf24;
  }

  .hero__dot--green {
    background: #34d399;
  }

  .hero__browser-url {
    font-size: 0.706rem;
    color: var(--color-text-tertiary);
  }

  .hero__browser-content {
    background: var(--color-bg);
  }

  .hero__browser-content img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem 1.5rem 2.5rem;
      min-height: 0;
    }

    .hero__text {
      padding-right: 0;
    }

    .hero__title {
      font-size: 2rem;
    }

    .hero__subtitle {
      font-size: 0.941rem;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
