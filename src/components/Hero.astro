---
---

<section class="hero">
  <div class="hero__text">
    <p class="hero__label">Open-source metamodeling platform</p>
    <h1 class="hero__title">
      Define languages.<br />
      Create models.<br />
      See results instantly.
    </h1>
    <p class="hero__subtitle">
      Cloud-based metamodeling workbench for research and education. Define
      your DSL, create models, apply transformations, and collaborate in real
      time. No installation. No code generation.
    </p>
    <div class="hero__actions">
      <a href="https://app.jjodel.io" class="btn btn-primary" rel="noopener">
        Try Jjodel →
      </a>
      <a href="https://docs.jjodel.io" class="btn btn-secondary" rel="noopener">
        Read the docs
      </a>
    </div>
  </div>

  <div class="hero__browser">
    <div class="hero__browser-bar">
      <div class="hero__browser-dots">
        <span class="hero__dot hero__dot--red"></span>
        <span class="hero__dot hero__dot--yellow"></span>
        <span class="hero__dot hero__dot--green"></span>
      </div>
      <span class="hero__browser-url">app.jjodel.io</span>
    </div>
    <div class="hero__browser-content">
      <button class="hero__zoom" type="button" aria-label="Expand screenshot">
        <img
          src="/jjodel-screenshot.png"
          alt="Jjodel Megamodel view showing metamodels, models, transformations, and their relationships"
        />
      </button>
    </div>
  </div>
</section>

<div class="lightbox" id="hero-lightbox" hidden>
  <button class="lightbox__close" type="button" aria-label="Close">×</button>
  <div class="lightbox__wrap">
    <img
      src="/jjodel-screenshot.png"
      alt="Jjodel Megamodel view showing metamodels, models, transformations, and their relationships"
    />
    <button type="button" class="hotspot hotspot--metamodel">
      <span class="hotspot__label">Metamodel</span>
      <span class="hotspot__tip">Define your domain structure — classes, attributes, and references. The metamodel is the foundation: everything else derives from it.</span>
    </button>
    <button type="button" class="hotspot hotspot--sources">
      <span class="hotspot__label">Source Models</span>
      <span class="hotspot__tip">Create model instances that conform to your metamodel. Edit them visually and see validation in real time.</span>
    </button>
    <button type="button" class="hotspot hotspot--transformations">
      <span class="hotspot__label">Transformations</span>
      <span class="hotspot__tip">Write model transformations in JjTL. Define rules and mappings to transform source models into target models automatically.</span>
    </button>
    <button type="button" class="hotspot hotspot--generated">
      <span class="hotspot__label">Generated Models</span>
      <span class="hotspot__tip">Models produced by executing transformations. Fully traceable back to their source models and transformation rules.</span>
    </button>
  </div>
</div>

<script>
  const trigger = document.querySelector<HTMLButtonElement>('.hero__zoom');
  const lightbox = document.getElementById('hero-lightbox');
  const closeBtn = document.querySelector<HTMLButtonElement>('.lightbox__close');

  function open() {
    if (!lightbox) return;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function close() {
    if (!lightbox) return;
    lightbox.hidden = true;
    document.body.style.overflow = '';
  }

  trigger?.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox && !lightbox.hidden) close();
  });
</script>

<style>
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 2rem 3.5rem;
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 2rem;
    align-items: center;
    min-height: 440px;
  }

  .hero__text {
    padding-right: 2rem;
  }

  .hero__label {
    font-size: 0.706rem;
    font-weight: 600;
    color: var(--jj-amber-600);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 0 1rem;
  }

  .hero__title {
    font-size: 2.75rem;
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
  }

  .hero__subtitle {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0 0 1.75rem;
  }

  .hero__actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero__browser {
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  .hero__browser-bar {
    background: var(--color-bg-secondary);
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .hero__browser-dots {
    display: flex;
    gap: 5px;
  }

  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .hero__dot--red {
    background: #f87171;
  }

  .hero__dot--yellow {
    background: #fbbf24;
  }

  .hero__dot--green {
    background: #34d399;
  }

  .hero__browser-url {
    font-size: 0.706rem;
    color: var(--color-text-tertiary);
  }

  .hero__browser-content {
    background: var(--color-bg);
  }

  .hero__zoom {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
  }

  .hero__zoom img {
    width: 100%;
    height: auto;
    display: block;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.88);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    cursor: zoom-out;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox__wrap {
    position: relative;
    display: inline-block;
    line-height: 0;
  }

  .lightbox__wrap img {
    display: block;
    max-width: calc(100vw - 4rem);
    max-height: calc(100vh - 4rem);
    width: auto;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: 0 16px 64px rgba(0, 0, 0, 0.4);
  }

  .hotspot {
    position: absolute;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: border-color 0.2s, background-color 0.2s;
  }

  .hotspot:hover,
  .hotspot:focus-visible {
    border-color: rgba(255, 255, 255, 0.8);
    background: rgba(255, 255, 255, 0.14);
    outline: none;
  }

  .hotspot__label {
    position: absolute;
    top: 8px;
    left: 8px;
    background: rgba(15, 23, 42, 0.82);
    color: var(--jj-white);
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    line-height: 1.3;
  }

  .hotspot--metamodel {
    left: 2%;
    top: 1%;
    width: 24%;
    height: 28%;
  }

  .hotspot--sources {
    left: 1%;
    top: 55%;
    width: 21%;
    height: 40%;
  }

  .hotspot--transformations {
    left: 29%;
    top: 1%;
    width: 38%;
    height: 62%;
  }

  .hotspot--generated {
    left: 65%;
    top: 38%;
    width: 34%;
    height: 60%;
  }

  .hotspot--generated .hotspot__tip {
    top: auto;
    bottom: calc(100% + 8px);
  }

  .hotspot__tip {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(15, 23, 42, 0.95);
    color: var(--jj-white);
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 13px;
    line-height: 1.4;
    width: max-content;
    max-width: min(280px, 90vw);
    text-align: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    z-index: 10;
  }

  .hotspot:hover .hotspot__tip,
  .hotspot:focus-visible .hotspot__tip {
    opacity: 1;
  }

  .lightbox__close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    background: none;
    border: 0;
    color: var(--jj-white);
    font-size: 32px;
    line-height: 1;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    opacity: 0.8;
  }

  .lightbox__close:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem 1.5rem 2.5rem;
      min-height: 0;
    }

    .hero__text {
      padding-right: 0;
    }

    .hero__title {
      font-size: 2rem;
    }

    .hero__subtitle {
      font-size: 0.941rem;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
