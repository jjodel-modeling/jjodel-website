---
import { getCollection } from 'astro:content';

const limit = 6;

const activities = await getCollection('activity', ({ data }) => !data.draft);
const publications = await getCollection('publications');

type FeedItem = {
  type: 'talk' | 'keynote' | 'paper' | 'release' | 'project';
  title: string;
  venue: string;
  date: Date;
  url?: string;
};

const feed: FeedItem[] = [
  ...activities.map((a): FeedItem => ({
    type: a.data.type,
    title: a.data.title,
    venue: a.data.venue,
    date: a.data.date,
    url: a.data.url,
  })),
  ...publications.map((p): FeedItem => ({
    type: 'paper',
    title: p.data.title,
    venue: `${p.data.venue}, ${p.data.year}`,
    date: p.data.date,
    url: p.data.doi ? `https://doi.org/${p.data.doi}` : p.data.fulltext,
  })),
]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, limit);

const typeLabel: Record<FeedItem['type'], string> = {
  paper: 'Paper',
  talk: 'Talk',
  keynote: 'Keynote',
  release: 'Release',
  project: 'Project',
};
---

<section class="section-lg">
  <div class="container-wide">
    <div class="feed-head">
      <h2 class="feed-heading">Latest activity</h2>
      <p class="feed-subtitle">Talks, publications, and project updates</p>
    </div>
    <ul class="feed">
      {
        feed.map((item) => (
          <li class="feed-row">
            <span class="feed-type tertiary">{typeLabel[item.type]}</span>
            <span class="feed-title">
              {item.url ? (
                <a href={item.url} rel="noopener">
                  {item.title} ↗
                </a>
              ) : (
                item.title
              )}
            </span>
            {item.venue && (
              <span class="feed-venue tertiary">{item.venue}</span>
            )}
          </li>
        ))
      }
    </ul>
    <a href="/activity/" class="feed-viewall">View all →</a>
  </div>
</section>

<style>
  .feed-head {
    margin-bottom: 2rem;
  }

  .feed-heading {
    font-size: 22px;
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 0.25rem;
  }

  .feed-subtitle {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .feed {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .feed-row {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: 1.25rem;
    align-items: baseline;
    padding: 14px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .feed-row:last-child {
    border-bottom: none;
  }

  .feed-type {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    font-weight: 500;
  }

  .feed-title {
    font-size: 16px;
    color: var(--color-text);
  }

  .feed-title a {
    color: var(--color-text);
  }

  .feed-title a:hover {
    color: var(--jj-blue-600);
  }

  .feed-venue {
    text-align: right;
    white-space: nowrap;
    font-size: 14px;
  }

  .feed-viewall {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 14px;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .feed-row {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .feed-venue {
      text-align: left;
    }
  }
</style>
