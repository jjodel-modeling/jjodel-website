---
interface Props {
  label?: string;
  variant?: 'primary' | 'secondary';
  size?: 'sm' | 'md' | 'lg';
}

const {
  label = 'Try Jjodel',
  variant = 'primary',
  size = 'md',
} = Astro.props;

const APP_URL = 'https://app.jjodel.io';
const BETA_URL = 'https://beta.jjodel.io';
---

<div
  class:list={[
    'try-jjodel-button',
    `try-jjodel-button--${variant}`,
    `try-jjodel-button--${size}`,
  ]}
>
  <a
    class="try-jjodel-button__main"
    href={APP_URL}
    target="_blank"
    rel="noopener"
  >
    {label}
  </a>
  <button
    type="button"
    class="try-jjodel-button__chevron"
    aria-haspopup="menu"
    aria-expanded="false"
    aria-label="Choose version"
  >
    <svg
      class="try-jjodel-button__chevron-icon"
      viewBox="0 0 20 20"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M5 7.5L10 12.5L15 7.5"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </button>
  <div class="try-jjodel-button__menu" role="menu" data-open="false">
    <a
      class="try-jjodel-button__item"
      href={APP_URL}
      role="menuitem"
      target="_blank"
      rel="noopener"
    >
      Current version
    </a>
    <a
      class="try-jjodel-button__item"
      href={BETA_URL}
      role="menuitem"
      target="_blank"
      rel="noopener"
    >
      Beta (3.0)
    </a>
  </div>
</div>

<script>
  const wrappers = Array.from(
    document.querySelectorAll<HTMLElement>('.try-jjodel-button'),
  );

  type Parts = {
    wrapper: HTMLElement;
    chevron: HTMLButtonElement;
    menu: HTMLElement;
  };

  function getParts(wrapper: HTMLElement): Parts | null {
    const chevron = wrapper.querySelector<HTMLButtonElement>(
      '.try-jjodel-button__chevron',
    );
    const menu = wrapper.querySelector<HTMLElement>(
      '.try-jjodel-button__menu',
    );
    if (!chevron || !menu) return null;
    return { wrapper, chevron, menu };
  }

  function closeAll(except?: HTMLElement) {
    wrappers.forEach((wrapper) => {
      if (wrapper === except) return;
      const parts = getParts(wrapper);
      if (!parts) return;
      if (parts.menu.dataset.open === 'true') {
        parts.menu.dataset.open = 'false';
        parts.chevron.setAttribute('aria-expanded', 'false');
      }
    });
  }

  wrappers.forEach((wrapper) => {
    const parts = getParts(wrapper);
    if (!parts) return;
    parts.chevron.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = parts.menu.dataset.open === 'true';
      closeAll(wrapper);
      parts.menu.dataset.open = isOpen ? 'false' : 'true';
      parts.chevron.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    });
  });

  document.addEventListener('click', (e) => {
    const target = e.target as Node | null;
    if (!target) return;
    wrappers.forEach((wrapper) => {
      if (wrapper.contains(target)) return;
      const parts = getParts(wrapper);
      if (!parts) return;
      if (parts.menu.dataset.open === 'true') {
        parts.menu.dataset.open = 'false';
        parts.chevron.setAttribute('aria-expanded', 'false');
      }
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    wrappers.forEach((wrapper) => {
      const parts = getParts(wrapper);
      if (!parts) return;
      if (parts.menu.dataset.open === 'true') {
        parts.menu.dataset.open = 'false';
        parts.chevron.setAttribute('aria-expanded', 'false');
        parts.chevron.focus();
      }
    });
  });
</script>

<style>
  .try-jjodel-button {
    position: relative;
    display: inline-flex;
    align-items: stretch;
    font-family: inherit;
  }

  .try-jjodel-button__main,
  .try-jjodel-button__chevron {
    font-family: inherit;
    font-weight: 500;
    line-height: 1.4;
    cursor: pointer;
    border: 1px solid transparent;
    transition:
      opacity 0.15s ease,
      background-color 0.15s ease;
  }

  .try-jjodel-button__main {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
    border-top-left-radius: var(--radius-md);
    border-bottom-left-radius: var(--radius-md);
    border-right: 0;
  }

  .try-jjodel-button__main:hover {
    text-decoration: none;
    opacity: 0.9;
  }

  .try-jjodel-button__chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-top-right-radius: var(--radius-md);
    border-bottom-right-radius: var(--radius-md);
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
  }

  .try-jjodel-button__chevron:hover {
    opacity: 0.9;
  }

  .try-jjodel-button__main:focus-visible,
  .try-jjodel-button__chevron:focus-visible {
    outline: 2px solid var(--jj-blue-600);
    outline-offset: 2px;
    z-index: 1;
  }

  .try-jjodel-button__chevron-icon {
    display: block;
    transition: transform 0.15s ease;
  }

  .try-jjodel-button__chevron[aria-expanded='true']
    .try-jjodel-button__chevron-icon {
    transform: rotate(180deg);
  }

  .try-jjodel-button--primary .try-jjodel-button__main,
  .try-jjodel-button--primary .try-jjodel-button__chevron {
    background: var(--color-text);
    color: var(--jj-white);
    border-color: var(--color-text);
  }

  .try-jjodel-button--primary .try-jjodel-button__chevron {
    border-left-color: rgba(255, 255, 255, 0.18);
  }

  .try-jjodel-button--secondary .try-jjodel-button__main,
  .try-jjodel-button--secondary .try-jjodel-button__chevron {
    background: var(--color-bg);
    color: var(--color-text);
    border-color: var(--color-border);
  }

  .try-jjodel-button--secondary .try-jjodel-button__main:hover,
  .try-jjodel-button--secondary .try-jjodel-button__chevron:hover {
    background: var(--color-bg-secondary);
    opacity: 1;
  }

  .try-jjodel-button--sm .try-jjodel-button__main {
    padding: 9px 16px;
    font-size: 14px;
  }
  .try-jjodel-button--sm .try-jjodel-button__chevron {
    padding: 0 10px;
  }
  .try-jjodel-button--sm .try-jjodel-button__chevron-icon {
    width: 14px;
    height: 14px;
  }

  .try-jjodel-button--md .try-jjodel-button__main {
    padding: 12px 20px;
    font-size: 15px;
  }
  .try-jjodel-button--md .try-jjodel-button__chevron {
    padding: 0 12px;
  }
  .try-jjodel-button--md .try-jjodel-button__chevron-icon {
    width: 16px;
    height: 16px;
  }

  .try-jjodel-button--lg .try-jjodel-button__main {
    padding: 14px 26px;
    font-size: 16px;
  }
  .try-jjodel-button--lg .try-jjodel-button__chevron {
    padding: 0 14px;
  }
  .try-jjodel-button--lg .try-jjodel-button__chevron-icon {
    width: 18px;
    height: 18px;
  }

  .try-jjodel-button__menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 200px;
    max-width: calc(100vw - 2rem);
    padding: 6px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    display: none;
    z-index: 50;
  }

  .try-jjodel-button__menu[data-open='true'] {
    display: block;
  }

  .try-jjodel-button__item {
    display: block;
    padding: 8px 12px;
    font-size: 14px;
    color: var(--color-text);
    border-radius: 6px;
    text-decoration: none;
  }

  .try-jjodel-button__item:hover {
    background: var(--color-bg-secondary);
    text-decoration: none;
  }

  .try-jjodel-button__item:focus-visible {
    outline: 2px solid var(--jj-blue-600);
    outline-offset: -2px;
  }
</style>
